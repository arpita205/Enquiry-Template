# ─── Microsoft Azure App Registration ────────────────────────────────────────
# Required for Microsoft Graph API (OAuth2 - Client Credentials flow)
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ─── Sender Mailbox ───────────────────────────────────────────────────────────
# The Office 365/Microsoft 365 mailbox to send from
SENDER_EMAIL=business@xecurra.com
SENDER_NAME=Xecurra Infinity LLP

# ─── Email Method ─────────────────────────────────────────────────────────────
# Choose: "graph" (Microsoft Graph API) or "smtp" (Office 365 SMTP)
EMAIL_METHOD=graph

# ─── SMTP Settings (only used if EMAIL_METHOD=smtp) ──────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=business@xecurra.com
SMTP_PASS=your-outlook-password-or-app-password

# ─── App Settings ─────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
